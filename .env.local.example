# =========================================================
#  Central da Compra — variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
# =========================================================

# --- Supabase ---
# Painel do Supabase > Project Settings > Data API (ou API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Painel do Supabase > Project Settings > API > service_role (SECRETA!)
# Nunca exponha essa chave no navegador. Só é usada no servidor.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# --- Painel admin ---
# Senha que você vai digitar para entrar em /admin. Escolha uma forte.
ADMIN_PASSWORD=troque-esta-senha
